# Server
PORT=5174
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=tarot_qa

# JWT
JWT_ACCESS_SECRET=your_access_secret_change_this_in_production
JWT_REFRESH_SECRET=your_refresh_secret_change_this_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# DeepSeek API（占卜 AI 解读必填）
# 密钥在 https://platform.deepseek.com/api_keys 创建；复制整段 sk-…，不要加引号，KEY= 后不要多空格。
# 若请求报 401：多为 Key 错误/过期/误用了其它平台的 Key；勿与 OpenAI、硅基流动等混用。
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# 官方默认即可；若用 OpenAI 兼容写法可改为 https://api.deepseek.com/v1（不要末尾斜杠）
DEEPSEEK_BASE_URL=https://api.deepseek.com

# CORS
# 逗号分隔；前后端分离开发时把 Vite 端口与公网访问地址都列上，例如:
# CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://你的域名或IP:5174
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174

# Redis (optional): enable cache when configured
# REDIS_URL=redis://127.0.0.1:6379

# Static frontend hosting toggle:
# true (default)  -> backend may serve tarot-vue/dist when present
# false           -> API-only mode; deploy frontend via Nginx/CDN separately
# SERVE_STATIC_FRONTEND=false

# Admin auth
# 用户名哈希用此 pepper；须与 admin_users 入库时一致。未配置时默认为 change-this-admin-pepper（与本地开发一致）。
# 若生产单独设置了随机 pepper，请用 npx tsx src/scripts/createAdminUser.ts 重新写入管理员，勿与本地混用不同 pepper。
# ADMIN_USERNAME_PEPPER=change-this-admin-pepper
# ADMIN_JWT_SECRET=replace-with-admin-jwt-secret

# Google 登录（与前端 VITE_GOOGLE_CLIENT_ID 使用同一 OAuth Web Client ID）
# GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com

# 密码重置邮件：重置链接 = APP_PUBLIC_ORIGIN + /reset-password?token=...
# APP_PUBLIC_ORIGIN=https://你的域名
# PASSWORD_RESET_EXPIRES_HOURS=1
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@example.com
